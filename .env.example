
# ==============================================================================
# DIGITAL BANKING PLATFORM - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and update values for your environment
# ==============================================================================

# ===== APPLICATION =====
APP_NAME=Digital Banking Platform
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development  # Options: development, staging, production

# ===== DATABASE =====
# SQLite (development)
# DB_URL=sqlite:///./bank.db

# PostgreSQL (production - uncomment to use)
# DB_URL=postgresql+asyncpg://user:password@localhost:5432/bankdb
DB_URL=sqlite:///./bank.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO_SQL=false

# ===== AUTHENTICATION & JWT =====
JWT_SECRET_KEY=your-super-secret-key-change-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_AUDIENCE=banking-app

# ===== REDIS (Optional - for caching) =====
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-redis-password

# ===== AI/FRAUD DETECTION =====
AI_ENABLED=true
AI_TIMEOUT_SECONDS=10
AI_MAX_RETRIES=3
AI_RETRY_DELAY_SECONDS=1

# ===== LOGGING =====
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, plain
# LOG_FILE_PATH=/var/log/banking-app/app.log

# ===== SECURITY =====
SECURITY_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
SECURITY_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
SECURITY_MAX_REQUEST_SIZE_MB=10

# ===== WEBSOCKET =====
WS_MAX_CONNECTIONS_PER_USER=5
WS_HEARTBEAT_INTERVAL_SECONDS=30
WS_CONNECTION_TIMEOUT_SECONDS=300

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:5173

# ===== EXTERNAL SERVICES =====
# Add external service URLs here if needed
# ML_SERVICE_URL=http://localhost:8001
# SMS_SERVICE_URL=https://sms-provider.com/api
